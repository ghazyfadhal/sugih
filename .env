# === Supabase API (Auth + Storage + REST) ===
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImJwanV1ZnJkemxjeG5pZW50ZnVpIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODE1MDgxNTksImV4cCI6MjA5NzA4NDE1OX0.dOGYDHJ2DIvXtC883_LcdpFnR9jCK-2NPsoaJyXW9WM
